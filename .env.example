# Telegram Bot Config
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_chat_id_here

# OCI Instance Config
# OCI_AD: Nome do Availability Domain (ex: xxxx:SA-SAOPAULO-1-AD-1)
OCI_AD=
# OCI_COMPARTMENT: OCID do seu compartimento ou tenancy root
OCI_COMPARTMENT=
# OCI_SUBNET: OCID da sua sub-rede pública
OCI_SUBNET=
# OCI_IMAGE: OCID da imagem Ubuntu/Oracle Linux desejada
OCI_IMAGE=
# OCI_INSTANCE_NAME: Nome da instância que será criada
OCI_INSTANCE_NAME=oracle-arm-instance

# Chave SSH pública para acesso à instância (sem aspas)
SSH_PUBLIC_KEY=ssh-rsa AAAAB3NzaC1... user@hostname
